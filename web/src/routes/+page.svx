    },
    {
      id: "daemon-trigger",
      prompt: "How should the loop pane run during the hour?",
      answer: "Keep the daemon running in the side pane so people can see the agentic turn and automatic pickup. Use the left Pi pane to start, stop, reset, and inspect the loop through the bespoke Pi extension/control surface. This teaches when to extend Pi with a tool or extension instead of only adding a skill.",
      placeholder: "Manual, polling, or both? What should the operator control?",
    },
    {
      id: "final-progression",
      prompt: "What visible Lakebed motion should the hour preserve?",
      answer: "Keep the current Lakebed surface energy: list view, Kanban board, and an event viewer. Show issues moving lane to lane, show what is in progress, and make the append-only event stream part of the lesson.",
      placeholder: "Which board/event motion is the final demo?",
    },
    {
      id: "take-home-proof",
      prompt: "What should the take-home artifact feel like?",
