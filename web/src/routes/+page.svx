<script lang="ts">
  import FlowChart from "$lib/flow-chart.svelte";
  import ReportLayout from "$lib/ReportLayout.svelte";
  import StatLine from "$lib/stat-line.svelte";
  import ToolGrid from "$lib/tool-grid.svelte";
  import WorkshopNav from "$lib/workshop-nav.svelte";
  import { lessons, site, stats } from "$lib/workshop-data";

  const tools = [
    { name: "Pi", icon: "spark", text: "The operator harness. We use it to prompt the next move, inspect evidence, and add small local controls." },
    { name: "Herdr", icon: "check", text: "The two-pane shape: one pane for Pi, one pane for runtime/status output." },
    { name: "Docker Compose", icon: "guard", text: "The recommended workshop computer. Tool versions stay boring and auth stays out of the image." },
    { name: "Lakebed", icon: "check", text: "The operator surface. It projects issue facts into list, board, and event views." },
    { name: "Effect", icon: "guard", text: "The boundary tool. Schemas and structured errors make sloppy issue input hard to ignore." },
    { name: "XState", icon: "check", text: "The lifecycle tool. We use it when the loop has real states, gates, retries, and recovery paths." },
    { name: "pi-subagents", icon: "chat", text: "Bounded specialist help. Scouts and reviewers produce artifacts; they do not get the keys by default." },
    { name: "Claude Code, Codex, OpenCode", icon: "chat", text: "Optional comparison harnesses in the workshop computer. Pi stays the main teaching surface." },
    { name: "Guardrails", icon: "guard", text: "pnpm, TypeScript, tsgo, oxlint, oxfmt, Ultracite, tests, and hooks are introduced as lesson work." },
    { name: "Matt Pocock skills", icon: "spark", text: "The reference for clear lesson progression. The core work here is Loopcraft through Pi." },
  ] as const;
</script>

<svelte:head>
  <title>{site.title}</title>
  <meta
    name="description"
    content="A hands-on workshop for building a local issue-progress loop with Pi, Herdr, Lakebed, typed events, receipts, and bounded agent leverage."
