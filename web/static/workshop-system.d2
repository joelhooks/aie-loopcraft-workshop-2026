direction: down

pi_pane: "1. Pi pane\nPi chat + Lakebed approval click" {
  shape: rectangle
  style.fill: "#fffdf8"
  style.stroke: "#9c9282"
}

lakebed: "2. Lakebed capsule\nBoard UI · issue-events API · append-only log" {
  shape: rectangle
  style.fill: "#f4f1e8"
  style.stroke: "#2f5f6f"
}

loop: "3. Local loop core\nHerdr daemon → adapter → Effect boundary → XState decision" {
  shape: rectangle
  style.fill: "#fbfaf5"
  style.stroke: "#9c9282"
}

evidence: "4. Durable evidence\nruns/receipts · runs/outbox · MEMORY.md" {
  shape: document
  style.fill: "#fffdf8"
  style.stroke: "#2f5f6f"
}

visible: "5. Visible progression\nready → in_progress or one next issue" {
  shape: rectangle
  style.fill: "#f4f1e8"
  style.stroke: "#2f5f6f"
}

pi_pane -> lakebed: "approval appends issue.updated"
lakebed -> loop: "daemon reads projected facts"
loop -> evidence: "writes why it moved"
loop -> lakebed: "appends progression event" {
  style.stroke-dash: 3
}
evidence -> visible: "receipt-backed board motion"
